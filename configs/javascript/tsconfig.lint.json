{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": [
    "../../**/*.ts",
    "../../**/*.tsx",
    "../../**/*.js",
    "../../**/*.jsx"
  ],
  "exclude": [
    "../../node_modules",
    "../../dist",
    "../../build",
    "../../coverage",
    "../../.next",
    "../../out",
    "../../target",
    "../../.code-standards"
  ]
}
